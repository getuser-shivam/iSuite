/// Comprehensive Monitoring, Logging, and Error Tracking Service
/// Provides enterprise-grade observability for Flutter applications
class MonitoringObservabilityService {
  static final MonitoringObservabilityService _instance = MonitoringObservabilityService._internal();
  factory MonitoringObservabilityService() => _instance;
  MonitoringObservabilityService._internal();

  final PerformanceOptimizationService _performanceService = PerformanceOptimizationService();
  final StreamController<MonitoringEvent> _monitoringEventController = StreamController.broadcast();

  Stream<MonitoringEvent> get monitoringEvents => _monitoringEventController.stream;

  // Logging system
  final Map<String, Logger> _loggers = {};
  final StreamController<LogEntry> _logStreamController = StreamController.broadcast();

  // Metrics collection
  final Map<String, MetricCollector> _metricCollectors = {};
  final Map<String, Gauge> _gauges = {};
  final Map<String, Counter> _counters = {};
  final Map<String, Histogram> _histograms = {};

  // Error tracking
  final Map<String, ErrorTracker> _errorTrackers = {};
  final StreamController<ErrorEvent> _errorStreamController = StreamController.broadcast();

  // Health monitoring
  final Map<String, HealthCheck> _healthChecks = {};
  final Timer? _healthCheckTimer;

  // Alerting system
  final Map<String, AlertRule> _alertRules = {};
  final StreamController<Alert> _alertStreamController = StreamController.broadcast();

  // Tracing
  final Map<String, TraceSpan> _activeSpans = {};
  final Map<String, List<TraceSpan>> _completedTraces = {};

  bool _isInitialized = false;

  // Configuration
  static const String _logDirectory = 'logs';
  static const String _metricsDirectory = 'metrics';
  static const int _maxLogFiles = 10;
  static const int _maxLogFileSize = 10 * 1024 * 1024; // 10MB
  static const Duration _healthCheckInterval = Duration(minutes: 1);
  static const Duration _metricsFlushInterval = Duration(minutes: 5);

  Timer? _metricsFlushTimer;

  /// Initialize monitoring service
  Future<void> initialize({
    List<LogConfig>? logConfigs,
    List<MetricConfig>? metricConfigs,
    List<HealthCheck>? healthChecks,
    List<AlertRule>? alertRules,
  }) async {
    if (_isInitialized) return;

    try {
      // Initialize directories
      await _initializeDirectories();

      // Initialize logging
      if (logConfigs != null) {
        for (final config in logConfigs) {
          await createLogger(config);
        }
      } else {
        await _initializeDefaultLoggers();
      }

      // Initialize metrics
      if (metricConfigs != null) {
        for (final config in metricConfigs) {
          await createMetricCollector(config);
        }
      } else {
        await _initializeDefaultMetrics();
      }

      // Initialize health checks
      if (healthChecks != null) {
        for (final check in healthChecks) {
          registerHealthCheck(check);
        }
      } else {
        await _initializeDefaultHealthChecks();
      }

      // Initialize alerting
      if (alertRules != null) {
        for (final rule in alertRules) {
          registerAlertRule(rule);
        }
      } else {
        await _initializeDefaultAlertRules();
      }

      // Start periodic tasks
      await _startPeriodicTasks();

      // Set up error handling
      await _setupErrorHandling();

      _isInitialized = true;
      _emitMonitoringEvent(MonitoringEventType.serviceInitialized);

    } catch (e) {
      _emitMonitoringEvent(MonitoringEventType.initializationFailed, error: e.toString());
      rethrow;
    }
  }

  /// Create a logger with specific configuration
  Future<Logger> createLogger(LogConfig config) async {
    final logger = Logger._internal(config);
    _loggers[config.name] = logger;

    // Set up log file rotation
    await logger.initialize();

    _emitMonitoringEvent(MonitoringEventType.loggerCreated,
      details: 'Logger: ${config.name}, Level: ${config.level}');

    return logger;
  }

  /// Get logger by name
  Logger? getLogger(String name) {
    return _loggers[name];
  }

  /// Log message with specific level and context
  void log({
    required String loggerName,
    required LogLevel level,
    required String message,
    Map<String, dynamic>? context,
    Object? error,
    StackTrace? stackTrace,
  }) {
    final logger = _loggers[loggerName];
    if (logger != null) {
      logger.log(level, message,
        context: context,
        error: error,
        stackTrace: stackTrace,
      );
    }
  }

  /// Create metric collector
  Future<MetricCollector> createMetricCollector(MetricConfig config) async {
    final collector = MetricCollector._internal(config);
    _metricCollectors[config.name] = collector;

    await collector.initialize();

    _emitMonitoringEvent(MonitoringEventType.metricCollectorCreated,
      details: 'Collector: ${config.name}, Type: ${config.type}');

    return collector;
  }

  /// Record metric value
  void recordMetric({
    required String collectorName,
    required String metricName,
    required double value,
    Map<String, String>? labels,
  }) {
    final collector = _metricCollectors[collectorName];
    if (collector != null) {
      collector.record(metricName, value, labels: labels);
    }
  }

  /// Increment counter metric
  void incrementCounter(String collectorName, String counterName, {
    Map<String, String>? labels,
  }) {
    final collector = _metricCollectors[collectorName];
    if (collector != null) {
      collector.incrementCounter(counterName, labels: labels);
    }
  }

  /// Record histogram observation
  void observeHistogram(String collectorName, String histogramName, double value, {
    Map<String, String>? labels,
  }) {
    final collector = _metricCollectors[collectorName];
    if (collector != null) {
      collector.observeHistogram(histogramName, value, labels: labels);
    }
  }

  /// Register health check
  void registerHealthCheck(HealthCheck check) {
    _healthChecks[check.name] = check;
    _emitMonitoringEvent(MonitoringEventType.healthCheckRegistered,
      details: 'Check: ${check.name}');
  }

  /// Perform health check
  Future<HealthStatus> performHealthCheck(String checkName) async {
    final check = _healthChecks[checkName];
    if (check == null) {
      return HealthStatus(
        name: checkName,
        status: HealthCheckStatus.unknown,
        message: 'Health check not found',
      );
    }

    try {
      final result = await check.check();
      _emitMonitoringEvent(MonitoringEventType.healthCheckPerformed,
        details: 'Check: $checkName, Status: ${result.status}');

      return result;

    } catch (e) {
      return HealthStatus(
        name: checkName,
        status: HealthCheckStatus.error,
        message: e.toString(),
      );
    }
  }

  /// Get all health statuses
  Future<Map<String, HealthStatus>> getAllHealthStatuses() async {
    final results = <String, HealthStatus>{};

    for (final checkName in _healthChecks.keys) {
      results[checkName] = await performHealthCheck(checkName);
    }

    return results;
  }

  /// Register alert rule
  void registerAlertRule(AlertRule rule) {
    _alertRules[rule.name] = rule;
    _emitMonitoringEvent(MonitoringEventType.alertRuleRegistered,
      details: 'Rule: ${rule.name}');
  }

  /// Evaluate alert rules
  Future<void> evaluateAlertRules() async {
    for (final rule in _alertRules.values) {
      try {
        final shouldAlert = await rule.evaluate(this);
        if (shouldAlert) {
          final alert = Alert(
            ruleName: rule.name,
            severity: rule.severity,
            message: rule.message,
            timestamp: DateTime.now(),
            context: await rule.getContext(),
          );

          _alertStreamController.add(alert);
          _emitMonitoringEvent(MonitoringEventType.alertTriggered,
            details: 'Alert: ${rule.name}, Severity: ${rule.severity}');

        }
      } catch (e) {
        log(
          loggerName: 'system',
          level: LogLevel.error,
          message: 'Failed to evaluate alert rule: ${rule.name}',
          error: e,
        );
      }
    }
  }

  /// Start trace span
  TraceSpan startSpan({
    required String operationName,
    String? parentSpanId,
    Map<String, String>? tags,
  }) {
    final spanId = _generateSpanId();
    final span = TraceSpan(
      spanId: spanId,
      operationName: operationName,
      parentSpanId: parentSpanId,
      startTime: DateTime.now(),
      tags: tags ?? {},
    );

    _activeSpans[spanId] = span;
    _emitMonitoringEvent(MonitoringEventType.spanStarted,
      details: 'Span: $spanId, Operation: $operationName');

    return span;
  }

  /// End trace span
  void endSpan(String spanId, {Map<String, String>? additionalTags}) {
    final span = _activeSpans[spanId];
    if (span != null) {
      span.endTime = DateTime.now();
      span.duration = span.endTime!.difference(span.startTime);

      if (additionalTags != null) {
        span.tags.addAll(additionalTags);
      }

      // Move to completed traces
      final traceId = span.parentSpanId ?? span.spanId;
      _completedTraces.putIfAbsent(traceId, () => []).add(span);
      _activeSpans.remove(spanId);

      _emitMonitoringEvent(MonitoringEventType.spanEnded,
        details: 'Span: $spanId, Duration: ${span.duration!.inMilliseconds}ms');
    }
  }

  /// Track operation with automatic span management
  Future<T> trackOperation<T>({
    required String operationName,
    required Future<T> Function() operation,
    Map<String, String>? tags,
  }) async {
    final span = startSpan(operationName: operationName, tags: tags);

    try {
      final result = await operation();
      endSpan(span.spanId, additionalTags: {'status': 'success'});
      return result;

    } catch (e) {
      endSpan(span.spanId, additionalTags: {
        'status': 'error',
        'error': e.toString(),
      });
      rethrow;
    }
  }

  /// Report error with context
  void reportError({
    required Object error,
    required StackTrace stackTrace,
    String? userId,
    String? sessionId,
    Map<String, dynamic>? context,
    ErrorSeverity severity = ErrorSeverity.medium,
  }) {
    final errorEvent = ErrorEvent(
      errorId: _generateErrorId(),
      error: error,
      stackTrace: stackTrace,
      userId: userId,
      sessionId: sessionId,
      context: context,
      severity: severity,
      timestamp: DateTime.now(),
    );

    _errorStreamController.add(errorEvent);

    // Log the error
    log(
      loggerName: 'error',
      level: LogLevel.error,
      message: error.toString(),
      context: context,
      error: error,
      stackTrace: stackTrace,
    );

    _emitMonitoringEvent(MonitoringEventType.errorReported,
      details: 'Error: ${error.toString()}, Severity: $severity');
  }

  /// Get system metrics
  Future<SystemMetrics> getSystemMetrics() async {
    final memoryInfo = await _getMemoryInfo();
    final cpuInfo = await _getCpuInfo();
    final diskInfo = await _getDiskInfo();
    final networkInfo = await _getNetworkInfo();

    return SystemMetrics(
      memoryUsage: memoryInfo,
      cpuUsage: cpuInfo,
      diskUsage: diskInfo,
      networkStats: networkInfo,
      timestamp: DateTime.now(),
    );
  }

  /// Export monitoring data
  Future<String> exportMonitoringData({
    DateTime? startTime,
    DateTime? endTime,
    bool includeLogs = true,
    bool includeMetrics = true,
    bool includeErrors = true,
    bool includeTraces = false,
  }) async {
    final data = <String, dynamic>{};
    final now = DateTime.now();
    final start = startTime ?? now.subtract(const Duration(hours: 24));
    final end = endTime ?? now;

    if (includeLogs) {
      data['logs'] = await _exportLogs(start, end);
    }

    if (includeMetrics) {
      data['metrics'] = await _exportMetrics(start, end);
    }

    if (includeErrors) {
      data['errors'] = await _exportErrors(start, end);
    }

    if (includeTraces) {
      data['traces'] = await _exportTraces(start, end);
    }

    return json.encode(data);
  }

  /// Get monitoring dashboard data
  Future<MonitoringDashboard> getMonitoringDashboard() async {
    final healthStatuses = await getAllHealthStatuses();
    final systemMetrics = await getSystemMetrics();
    final recentErrors = await _getRecentErrors();
    final activeAlerts = await _getActiveAlerts();

    return MonitoringDashboard(
      healthStatuses: healthStatuses,
      systemMetrics: systemMetrics,
      recentErrors: recentErrors,
      activeAlerts: activeAlerts,
      timestamp: DateTime.now(),
    );
  }

