  void dispose() {
    _healthCheckTimer?.cancel();
    _metricsFlushTimer?.cancel();
    _logStreamController.close();
    _errorStreamController.close();
    _alertStreamController.close();
    _monitoringEventController.close();
  }
}

/// Logger class for structured logging
class Logger {
  final LogConfig config;
  File? _logFile;
  IOSink? _logSink;
  int _currentFileSize = 0;

  Logger._internal(this.config);

  Future<void> initialize() async {
    if (config.enableFileOutput) {
      await _initializeLogFile();
    }
  }

  void log(
    LogLevel level,
    String message, {
    Map<String, dynamic>? context,
    Object? error,
    StackTrace? stackTrace,
  }) {
    if (level.index < config.level.index) return;

    final entry = LogEntry(
      timestamp: DateTime.now(),
      level: level,
      loggerName: config.name,
      message: message,
      context: context,
      error: error?.toString(),
      stackTrace: stackTrace?.toString(),
    );

    // Console output
    if (config.enableConsoleOutput) {
      _outputToConsole(entry);
    }

    // File output
    if (config.enableFileOutput && _logSink != null) {
      _outputToFile(entry);
    }

    // Stream output
    MonitoringObservabilityService()._logStreamController.add(entry);
  }

  Future<void> _initializeLogFile() async {
    final fileName = '${config.name}_${DateTime.now().toIso8601String().split('T')[0]}.log';
    final filePath = '${MonitoringObservabilityService._logDirectory}/$fileName';

    _logFile = File(filePath);
    _logSink = _logFile!.openWrite(mode: FileMode.append);

    // Check if file rotation is needed
    if (await _logFile!.exists()) {
      _currentFileSize = await _logFile!.length();
      if (_currentFileSize >= config.maxFileSize) {
        await _rotateLogFile();
      }
    }
  }

  Future<void> _rotateLogFile() async {
    if (_logSink != null) {
      await _logSink!.close();
    }

    // Rename current file
    final timestamp = DateTime.now().millisecondsSinceEpoch;
    final rotatedFileName = '${config.name}_${timestamp}.log';
    final rotatedPath = '${MonitoringObservabilityService._logDirectory}/$rotatedFileName';

    await _logFile!.rename(rotatedPath);

    // Clean up old files
    await _cleanupOldLogFiles();

    // Create new file
    await _initializeLogFile();
  }

  Future<void> _cleanupOldLogFiles() async {
    final dir = Directory(MonitoringObservabilityService._logDirectory);
    if (!await dir.exists()) return;

    final files = await dir.list().toList();
    final logFiles = files
        .whereType<File>()
        .where((file) => file.path.contains(config.name))
        .toList();

    logFiles.sort((a, b) => b.lastModifiedSync().compareTo(a.lastModifiedSync()));

    // Keep only maxFiles most recent files
    if (logFiles.length > config.maxFiles) {
      for (final file in logFiles.sublist(config.maxFiles)) {
        try {
          await file.delete();
        } catch (e) {
          // Ignore deletion errors
        }
      }
    }
  }

  void _outputToConsole(LogEntry entry) {
    final levelStr = entry.level.toString().split('.').last.toUpperCase();
    final timestamp = entry.timestamp.toIso8601String();
    final output = '[$timestamp] $levelStr ${entry.loggerName}: ${entry.message}';

    if (entry.level == LogLevel.error) {
      // ignore: avoid_print
      print('\x1B[31m$output\x1B[0m'); // Red for errors
    } else if (entry.level == LogLevel.warning) {
      // ignore: avoid_print
      print('\x1B[33m$output\x1B[0m'); // Yellow for warnings
    } else {
      // ignore: avoid_print
      print(output);
    }
  }

  void _outputToFile(LogEntry entry) {
    final jsonEntry = json.encode(entry.toJson());
    _logSink!.writeln(jsonEntry);
    _currentFileSize += jsonEntry.length + 1; // +1 for newline

    // Check if rotation is needed
    if (_currentFileSize >= config.maxFileSize) {
      _rotateLogFile();
    }
  }

  Future<void> close() async {
    await _logSink?.close();
  }
}

