  Future<void> _initializeDefaultHealthChecks() async {
    // Memory health check
    registerHealthCheck(HealthCheck(
      name: 'memory',
      description: 'Memory usage health check',
      check: () async {
        final metrics = await getSystemMetrics();
        final memoryUsagePercent = metrics.memoryUsage.used / metrics.memoryUsage.total;

        if (memoryUsagePercent > 0.9) {
          return HealthStatus(
            name: 'memory',
            status: HealthCheckStatus.critical,
            message: 'Memory usage is critically high: ${(memoryUsagePercent * 100).round()}%',
          );
        } else if (memoryUsagePercent > 0.8) {
          return HealthStatus(
            name: 'memory',
            status: HealthCheckStatus.warning,
            message: 'Memory usage is high: ${(memoryUsagePercent * 100).round()}%',
          );
        } else {
          return HealthStatus(
            name: 'memory',
            status: HealthCheckStatus.healthy,
            message: 'Memory usage is normal: ${(memoryUsagePercent * 100).round()}%',
          );
        }
      },
    ));

    // Disk health check
    registerHealthCheck(HealthCheck(
      name: 'disk',
      description: 'Disk space health check',
      check: () async {
        final metrics = await getSystemMetrics();
        final diskUsagePercent = metrics.diskUsage.used / metrics.diskUsage.total;

        if (diskUsagePercent > 0.95) {
          return HealthStatus(
            name: 'disk',
            status: HealthCheckStatus.critical,
            message: 'Disk usage is critically high: ${(diskUsagePercent * 100).round()}%',
          );
        } else if (diskUsagePercent > 0.85) {
          return HealthStatus(
            name: 'disk',
            status: HealthCheckStatus.warning,
            message: 'Disk usage is high: ${(diskUsagePercent * 100).round()}%',
          );
        } else {
          return HealthStatus(
            name: 'disk',
            status: HealthCheckStatus.healthy,
            message: 'Disk usage is normal: ${(diskUsagePercent * 100).round()}%',
          );
        }
      },
    ));

    // Network health check
    registerHealthCheck(HealthCheck(
      name: 'network',
      description: 'Network connectivity health check',
      check: () async {
        try {
          // Simple connectivity check
          final result = await InternetAddress.lookup('google.com');
          if (result.isNotEmpty && result[0].rawAddress.isNotEmpty) {
            return HealthStatus(
              name: 'network',
              status: HealthCheckStatus.healthy,
              message: 'Network connectivity is healthy',
            );
          } else {
            return HealthStatus(
              name: 'network',
              status: HealthCheckStatus.error,
              message: 'Network connectivity check failed',
            );
          }
        } catch (e) {
          return HealthStatus(
            name: 'network',
            status: HealthCheckStatus.error,
            message: 'Network connectivity error: ${e.toString()}',
          );
        }
      },
    ));
  }

  Future<void> _initializeDefaultAlertRules() async {
    // High memory usage alert
    registerAlertRule(AlertRule(
      name: 'high_memory_usage',
      description: 'Alert when memory usage exceeds 80%',
      severity: AlertSeverity.warning,
      message: 'Memory usage has exceeded 80%',
      evaluate: (service) async {
        final metrics = await service.getSystemMetrics();
        final memoryUsagePercent = metrics.memoryUsage.used / metrics.memoryUsage.total;
        return memoryUsagePercent > 0.8;
      },
      getContext: () async {
        final metrics = await getSystemMetrics();
        return {
          'memory_used': metrics.memoryUsage.used,
          'memory_total': metrics.memoryUsage.total,
          'memory_percent': (metrics.memoryUsage.used / metrics.memoryUsage.total * 100).round(),
        };
      },
    ));

    // High error rate alert
    registerAlertRule(AlertRule(
      name: 'high_error_rate',
      description: 'Alert when error rate exceeds threshold',
      severity: AlertSeverity.error,
      message: 'Error rate has exceeded acceptable threshold',
      evaluate: (service) async {
        // Check recent error count
        final recentErrors = await _getRecentErrors(limit: 100);
        final errorRate = recentErrors.length / 60; // errors per minute
        return errorRate > 5; // More than 5 errors per minute
      },
      getContext: () async {
        final recentErrors = await _getRecentErrors(limit: 100);
        return {
          'error_count': recentErrors.length,
          'time_window': '60 minutes',
          'error_rate': recentErrors.length / 60,
        };
      },
    ));
  }

  Future<void> _startPeriodicTasks() async {
    // Health check timer
    Timer.periodic(_healthCheckInterval, (timer) async {
      await evaluateAlertRules();
    });

    // Metrics flush timer
    _metricsFlushTimer = Timer.periodic(_metricsFlushInterval, (timer) async {
      await _flushMetrics();
    });
  }

  Future<void> _setupErrorHandling() async {
    // Set up global error handling
    FlutterError.onError = (FlutterErrorDetails details) {
      reportError(
        error: details.exception,
        stackTrace: details.stack ?? StackTrace.empty,
        context: {
          'library': details.library,
          'context': details.context?.toString(),
        },
        severity: ErrorSeverity.high,
      );
    };

    // Handle platform errors
    PlatformDispatcher.instance.onError = (error, stack) {
      reportError(
        error: error,
        stackTrace: stack,
        severity: ErrorSeverity.critical,
      );
      return true;
    };
  }

  Future<void> _flushMetrics() async {
    for (final collector in _metricCollectors.values) {
      await collector.flush();
    }
  }

