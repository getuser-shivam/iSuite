class MetricCollector {
  final MetricConfig config;
  final Map<String, dynamic> _metrics = {};

  MetricCollector._internal(this.config);

  Future<void> initialize() async {
    // Initialize metric storage
  }

  void record(String metricName, double value, {Map<String, String>? labels}) {
    final key = _generateMetricKey(metricName, labels);
    _metrics[key] = {
      'value': value,
      'timestamp': DateTime.now(),
      'labels': labels,
    };
  }

  void incrementCounter(String counterName, {Map<String, String>? labels}) {
    final key = _generateMetricKey(counterName, labels);
    final current = (_metrics[key] as Map<String, dynamic>?)?['value'] ?? 0;
    _metrics[key] = {
      'value': current + 1,
      'timestamp': DateTime.now(),
      'labels': labels,
    };
  }

  void observeHistogram(String histogramName, double value, {Map<String, String>? labels}) {
    final key = _generateMetricKey(histogramName, labels);
    final histogram = _metrics[key] as List<double>? ?? [];
    histogram.add(value);
    _metrics[key] = {
      'values': histogram,
      'timestamp': DateTime.now(),
      'labels': labels,
    };
  }

  Future<void> flush() async {
    // Flush metrics to storage or external system
  }

  String _generateMetricKey(String name, Map<String, String>? labels) {
    if (labels == null || labels.isEmpty) return name;

    final sortedLabels = labels.entries.toList()..sort((a, b) => a.key.compareTo(b.key));
    final labelString = sortedLabels.map((e) => '${e.key}=${e.value}').join(',');
    return '$name{$labelString}';
  }
}

class Gauge {
  final String name;
  final String description;
  double _value = 0.0;

  Gauge({
    required this.name,
    required this.description,
  });

  double get value => _value;

  void set(double value) {
    _value = value;
  }
}

class Counter {
  final String name;
  final String description;
  int _count = 0;

  Counter({
    required this.name,
    required this.description,
  });

  int get count => _count;

  void increment() {
    _count++;
  }

  void add(int value) {
    _count += value;
  }
}

class Histogram {
  final String name;
  final String description;
  final List<double> _observations = [];

  Histogram({
    required this.name,
    required this.description,
  });

  List<double> get observations => List.unmodifiable(_observations);

  void observe(double value) {
    _observations.add(value);
  }

  double get average => _observations.isEmpty ? 0.0 : _observations.reduce((a, b) => a + b) / _observations.length;

  double get percentile(double p) {
    if (_observations.isEmpty) return 0.0;

    final sorted = List<double>.from(_observations)..sort();
    final index = ((sorted.length - 1) * p).round();
    return sorted[index];
  }
}

