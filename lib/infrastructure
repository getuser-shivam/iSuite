  String _generateSpanId() {
    return DateTime.now().millisecondsSinceEpoch.toString() +
           '_' +
           (1000 + (9999 - 1000) * (DateTime.now().microsecond / 1000000)).round().toString();
  }

  String _generateErrorId() {
    return 'error_' + DateTime.now().millisecondsSinceEpoch.toString();
  }

  void _emitMonitoringEvent(MonitoringEventType type, {
    String? details,
    String? error,
  }) {
    final event = MonitoringEvent(
      type: type,
      timestamp: DateTime.now(),
      details: details,
